# =========================================================================
# DAGANTA ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env (for sensitive server variables) 
# and .env.local (for public frontend and local dev database variables).
# =========================================================================

# Database Connection (PostgreSQL provider via Prisma)
DATABASE_PROVIDER="postgres"
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]?schema=public"
# Optional at runtime, required for Prisma migrations when your provider uses a pooled DATABASE_URL.
DIRECT_URL="postgresql://[USER]:[PASSWORD]@[DIRECT_HOST]:[PORT]/[DATABASE]?schema=public"
# Managed PostgreSQL providers often require SSL and a conservative pool.
# Example runtime URL:
# DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]?schema=public&sslmode=require&connection_limit=1&pool_timeout=20"
# Example direct migration URL:
# DIRECT_URL="postgresql://[USER]:[PASSWORD]@[DIRECT_HOST]:[PORT]/[DATABASE]?schema=public&sslmode=require"

# Auth Provider
# Supported: credentials, demo, supabase
AUTH_PROVIDER="credentials"
AUTH_SECRET="replace-with-a-long-random-secret"
# Demo mode is internal/staging only. Never enable it for production auth.
DEMO_AUTH_ENABLED="false"

# Storage Provider
# Supported: local, supabase
STORAGE_PROVIDER="local"

# Optional Supabase Keys
# Required only when AUTH_PROVIDER=supabase or STORAGE_PROVIDER=supabase.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# App & Storefront Domains
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN="daganta.store"

# Security & Encryption
JWT_SECRET="your-jwt-secret-here"
ENCRYPTION_KEY="your-encryption-key-here"
WEBHOOK_SECRET="your-webhook-secret-here"

# Third-Party Vendor Integrations (MVP Placeholders)
DRIPSENDER_API_KEY="your-dripsender-api-key-here"
MAILKETING_SMTP_PASS="your-mailketing-smtp-pass-here"
MIDTRANS_SERVER_KEY="your-midtrans-server-key-here"
QSTASH_TOKEN="your-qstash-token-here"

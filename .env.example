# =========================================================================
# DAGANTA ENVIRONMENT VARIABLES EXAMPLE
# Local development: keep server secrets/database in .env and public Auth
# configuration in .env.local.
# VPS production: store as .env.production outside Git and restrict access.
# NEXT_PUBLIC_* values are embedded during `next build`; pass the same values
# as Docker build arguments and runtime environment variables.
# Do not define DATABASE_URL in both .env and .env.local with different values.
# =========================================================================

# Database Connection (Sumobase managed PostgreSQL via Prisma)
DATABASE_PROVIDER="postgres"
# Use the exact Sumobase Transaction Pooler connection string for runtime.
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[SUMOBASE_POOLER_HOST]:6432/[DATABASE]?schema=public"
# Use the separate Sumobase Direct Connection string for Prisma migrations.
# Do not reuse the Transaction Pooler URL here.
DIRECT_URL="postgresql://[USER]:[PASSWORD]@[SUMOBASE_DIRECT_HOST]:[DIRECT_PORT]/[DATABASE]?schema=public"
# Preserve the SSL and pooler parameters provided by Sumobase.
# URL-encode passwords that contain reserved URL characters.

# Auth Provider
# Supported: credentials, demo, supabase
AUTH_PROVIDER="credentials"
AUTH_SECRET="replace-with-a-long-random-secret"
# Demo mode is internal/staging only. Never enable it for production auth.
DEMO_AUTH_ENABLED="false"

# Storage Provider
# Supported: local, supabase
STORAGE_PROVIDER="local"

# Optional Supabase Keys
# Required only when AUTH_PROVIDER=supabase or STORAGE_PROVIDER=supabase.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# App & Storefront Domains
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN="daganta.store"

# Deployment Controls
# Database migrations are a dedicated release step and are not run by the app.
RUN_MIGRATIONS="false"
# Seed must never be enabled for normal production releases.
RUN_DB_SEED="false"
ALLOW_DB_SEED="false"

# Security & Encryption
JWT_SECRET="your-jwt-secret-here"
ENCRYPTION_KEY="your-encryption-key-here"
WEBHOOK_SECRET="your-webhook-secret-here"

# Third-Party Vendor Integrations (MVP Placeholders)
DRIPSENDER_API_KEY="your-dripsender-api-key-here"
MAILKETING_SMTP_PASS="your-mailketing-smtp-pass-here"
MIDTRANS_SERVER_KEY="your-midtrans-server-key-here"
QSTASH_TOKEN="your-qstash-token-here"

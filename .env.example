# =========================================================================
# DAGANTA ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env (for sensitive server variables) 
# and .env.local (for public frontend and local dev database variables).
# =========================================================================

# Database Connection (Supabase Dev - put in .env.local for local dev)
DATABASE_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# Supabase Keys
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# App & Storefront Domains
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN="daganta.store"

# Security & Encryption
JWT_SECRET="your-jwt-secret-here"
ENCRYPTION_KEY="your-encryption-key-here"
WEBHOOK_SECRET="your-webhook-secret-here"

# Third-Party Vendor Integrations (MVP Placeholders)
DRIPSENDER_API_KEY="your-dripsender-api-key-here"
MAILKETING_SMTP_PASS="your-mailketing-smtp-pass-here"
MIDTRANS_SERVER_KEY="your-midtrans-server-key-here"
QSTASH_TOKEN="your-qstash-token-here"

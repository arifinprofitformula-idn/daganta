datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  AGENT
  TENANT_OWNER
  TENANT_STAFF
  CUSTOMER
}

enum TenantStatus {
  ACTIVE
  EXPIRING_SOON
  GRACE_PERIOD
  LIMITED
  SUSPENDED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELED
  EXPIRED
  REFUNDED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRING_SOON
  GRACE_PERIOD
  LIMITED_MODE
  SUSPENDED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PAID
  VOID
}

enum PaymentProvider {
  MANUAL
  MIDTRANS
  XENDIT
  TRIPAY
}

enum PaymentMethod {
  MANUAL_TRANSFER
}

enum PaymentStatus {
  WAITING_PAYMENT
  WAITING_VERIFICATION
  VERIFIED
  REJECTED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  INTERNAL
}

enum NotificationEventStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELED
}

enum NotificationEventType {
  ORDER_CREATED
  PAYMENT_WAITING_VERIFICATION
  PAYMENT_VERIFIED
  PAYMENT_REJECTED
  ORDER_STATUS_UPDATED
  TENANT_SUBSCRIPTION_EXPIRING
  TENANT_SUBSCRIPTION_EXPIRED
}


// ==========================================
// IDENTITY & ACCESS
// ==========================================

model UserProfile {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  authUserId String?  @unique // Jembatan ke Supabase Auth
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  tenantMembers TenantMember[]
  ownedTenants  Tenant[]       @relation("TenantOwner")
  auditLogs     AuditLog[]     @relation("UserActor")
}

model Tenant {
  id                 String       @id @default(uuid())
  name               String
  slug               String       @unique
  subdomain          String       @unique
  status             TenantStatus @default(ACTIVE)
  ownerId            String
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  gracePeriodEndsAt  DateTime?
  limitedAt          DateTime?
  suspendedAt        DateTime?
  archivedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  owner             UserProfile          @relation("TenantOwner", fields: [ownerId], references: [id])
  members           TenantMember[]
  productCategories ProductCategory[]
  products          Product[]
  productVariants   ProductVariant[]
  customers         Customer[]
  orders            Order[]
  orderItems        OrderItem[]
  orderPayments     OrderPayment[]
  auditLogs         AuditLog[]
  addresses         Address[]
  subscriptions     TenantSubscription[]
  invoices          Invoice[]
  notificationEvents NotificationEvent[]
}

model TenantMember {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  role      UserRole @default(TENANT_STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

// ==========================================
// CATALOG
// ==========================================

model ProductCategory {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId]) // Indeks tenant untuk performa query
}

model Product {
  id          String        @id @default(uuid())
  tenantId    String
  categoryId  String?
  name        String
  slug        String
  description String        @db.Text
  status      ProductStatus @default(ACTIVE)
  basePrice   Decimal       @db.Decimal(12, 2)
  imageUrl    String?
  isFeatured  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants   ProductVariant[]
  orderItems OrderItem[]

  @@unique([tenantId, slug])
  @@index([tenantId]) // Indeks tenant untuk performa query
}

model ProductVariant {
  id         String   @id @default(uuid())
  tenantId   String
  productId  String
  name       String
  sku        String?
  price      Decimal  @db.Decimal(12, 2)
  stock      Int      @default(0)
  weightGram Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  // Indeks untuk sku nullable dan optimasi tenant
  @@index([sku])
  @@index([tenantId, productId, sku])
  @@index([tenantId]) // Indeks tenant untuk performa query
  @@index([tenantId, sku]) // Indeks komposit tenant & sku
}

// ==========================================
// CUSTOMER & ORDER
// ==========================================

model Customer {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  phone      String
  email      String?
  address    String?  @db.Text
  provinceId String?
  regencyId  String?
  districtId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  province Province? @relation(fields: [provinceId], references: [id], onDelete: SetNull)
  regency  Regency?  @relation(fields: [regencyId], references: [id], onDelete: SetNull)
  district District? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  orders   Order[]
  notificationEvents NotificationEvent[]

  @@index([tenantId]) // Indeks tenant untuk performa query
}

model Order {
  id            String      @id @default(uuid())
  tenantId      String
  customerId    String?
  orderNumber   String
  status        OrderStatus @default(DRAFT)
  subtotal      Decimal     @db.Decimal(12, 2)
  shippingCost  Decimal     @default(0.00) @db.Decimal(12, 2)
  discountTotal Decimal     @default(0.00) @db.Decimal(12, 2)
  grandTotal    Decimal     @db.Decimal(12, 2)
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payment  OrderPayment?
  notificationEvents NotificationEvent[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId]) // Indeks tenant untuk performa query
}

model OrderPayment {
  id         String          @id @default(uuid())
  tenantId   String
  orderId    String          @unique
  provider   PaymentProvider @default(MANUAL)
  method     PaymentMethod   @default(MANUAL_TRANSFER)
  status     PaymentStatus   @default(WAITING_PAYMENT)
  amount     Decimal         @db.Decimal(12, 2)
  proofNote  String?         @db.Text
  adminNote  String?         @db.Text
  verifiedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, orderId])
}

model WebhookEvent {
  id               String             @id @default(uuid())
  provider         PaymentProvider
  eventType        String
  eventId          String?
  idempotencyKey   String
  status           WebhookEventStatus @default(RECEIVED)
  payload          Json
  sanitizedHeaders Json?
  errorMessage     String?            @db.Text
  receivedAt       DateTime           @default(now())
  processedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([provider, idempotencyKey])
  @@index([provider, status])
  @@index([receivedAt])
}

model OrderItem {
  id                  String   @id @default(uuid())
  tenantId            String
  orderId             String
  productId           String
  variantId           String?
  productNameSnapshot String
  variantNameSnapshot String?
  quantity            Int
  unitPrice           Decimal  @db.Decimal(12, 2)
  totalPrice          Decimal  @db.Decimal(12, 2)
  weightGram          Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt // Konsisten dengan model lain

  // Relations
  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([tenantId]) // Indeks tenant untuk performa query
}

// ==========================================
// ADDRESS & LOGISTICS REGION
// ==========================================

model Address {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  recipientName String
  phone         String
  streetAddress String   @db.Text
  provinceId    String
  regencyId     String
  districtId    String
  postalCode    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  province Province @relation(fields: [provinceId], references: [id])
  regency  Regency  @relation(fields: [regencyId], references: [id])
  district District @relation(fields: [districtId], references: [id])

  @@index([tenantId]) // Indeks tenant untuk performa query
}

model Province {
  id             String   @id
  name           String
  normalizedName String
  externalCode   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  regencies Regency[]
  customers Customer[]
  addresses Address[]

  @@index([normalizedName]) // Indeks pencarian nama wilayah ternormalisasi
}

model Regency {
  id             String   @id
  provinceId     String
  name           String
  normalizedName String
  type           String?
  externalCode   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  province  Province   @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  districts District[]
  customers Customer[]
  addresses Address[]

  @@index([provinceId, normalizedName]) // Indeks logistik terstruktur
}

model District {
  id             String   @id
  regencyId      String
  name           String
  normalizedName String
  externalCode   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  regency   Regency    @relation(fields: [regencyId], references: [id], onDelete: Cascade)
  customers Customer[]
  addresses Address[]

  @@index([regencyId, normalizedName]) // Indeks logistik terstruktur
}

// ==========================================
// BILLING
// ==========================================

model SubscriptionPlan {
  id                  String       @id @default(uuid())
  code                String       @unique
  name                String
  description         String?      @db.Text
  billingCycle        BillingCycle
  price               Decimal      @db.Decimal(12, 2)
  currency            String       @default("IDR")
  productLimit        Int
  activeMonths        Int
  transactionFeeCents Int          @default(0)
  trialDays           Int          @default(14)
  gracePeriodDays     Int          @default(7)
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  subscriptions TenantSubscription[]
  invoices      Invoice[]            @relation("InvoicePlan")
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  tenantId           String
  planId             String
  status             SubscriptionStatus @default(TRIAL)
  billingCycle       BillingCycle
  trialStartsAt      DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  gracePeriodEndsAt  DateTime?
  canceledAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model Invoice {
  id                   String        @id @default(uuid())
  tenantId             String
  subscriptionId       String?
  planId               String
  invoiceNumber        String
  status               InvoiceStatus @default(DRAFT)
  billingCycle         BillingCycle
  amount               Decimal       @db.Decimal(12, 2)
  currency             String        @default("IDR")
  productLimitSnapshot Int
  periodStart          DateTime?
  periodEnd            DateTime?
  issuedAt             DateTime      @default(now())
  dueAt                DateTime?
  paidAt               DateTime?
  voidedAt             DateTime?
  paymentInstructions  String?       @db.Text
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription TenantSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan         SubscriptionPlan    @relation("InvoicePlan", fields: [planId], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([subscriptionId])
  @@index([planId])
}

// ==========================================
// SYSTEM (AUDIT)
// ==========================================

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // Relations
  tenant Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  UserProfile? @relation("UserActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId]) // Indeks tenant untuk performa query
}

model NotificationEvent {
  id            String                  @id @default(uuid())
  tenantId      String?
  orderId       String?
  customerId    String?
  channel       NotificationChannel
  type          NotificationEventType
  status        NotificationEventStatus @default(PENDING)
  recipient     String?
  subject       String?
  message       String                  @db.Text
  payload       Json?
  attemptCount  Int                     @default(0)
  maxAttempts   Int                     @default(3)
  nextAttemptAt DateTime?
  sentAt        DateTime?
  failedAt      DateTime?
  lastError     String?                 @db.Text
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  // Relations
  tenant        Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order         Order?                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer      Customer?               @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([status, nextAttemptAt])
  @@index([type])
  @@index([orderId])
}
